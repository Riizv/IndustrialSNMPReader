<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" prefHeight="400.0" prefWidth="600.0"
      style="-fx-background-color: #2c3e50;" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.industrialsnmpreader.LoginController"
      stylesheets="@style.css">

    <Label text="Logowanie" textFill="WHITE">
        <font>
            <Font name="System Bold" size="28.0"/>
        </font>
    </Label>

    <VBox maxWidth="300.0" spacing="10.0"
          style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10;">
        <Label text="Użytkownik:"/>
        <TextField fx:id="usernameField" promptText="admin"/>

        <Label text="Hasło:"/>
        <PasswordField fx:id="passwordField" promptText="haslo123"/>

        <Button fx:id="loginButton" text="Zaloguj" onAction="#onLoginClick" defaultButton="true"
                maxWidth="Infinity" styleClass="button-logout"/>

        <Label fx:id="errorLabel" textFill="#e74c3c" wrapText="true"/>
    </VBox>
</VBox>
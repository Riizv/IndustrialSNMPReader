<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="500.0" prefWidth="900.0" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.industrialsnmpreader.IndustrialSNMPController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #004990; -fx-padding: 15;">
            <Label text="Industrial SNMP Monitor" textFill="WHITE" style="-fx-font-size: 20; -fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Wyloguj" onAction="#onLogoutClick" />
        </HBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.7">
            <VBox spacing="10" style="-fx-padding: 10;">
                <TableView fx:id="deviceTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="40" />
                        <TableColumn fx:id="colIp" text="IP" prefWidth="120" />
                        <TableColumn fx:id="colOid" text="OID" prefWidth="180" />
                        <TableColumn fx:id="colTemp" text="Temp." prefWidth="80" />
                        <TableColumn fx:id="colUpdate" text="Odczyt" prefWidth="120" />
                    </columns>
                </TableView>
            </VBox>
            <VBox spacing="15" style="-fx-padding: 20;">
                <Label text="Dodaj Urządzenie" style="-fx-font-weight: bold;" />
                <TextField fx:id="ipField" promptText="Adres IP" />
                <TextField fx:id="oidField" promptText="OID" />
                <Button text="Dodaj" onAction="#onAddDevice" maxWidth="Infinity" />
                <Button text="Usuń" onAction="#onDeleteDevice" maxWidth="Infinity" />
                <Label fx:id="statusLabel" text="Gotowy" />
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
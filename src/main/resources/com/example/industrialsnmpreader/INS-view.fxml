<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<BorderPane prefHeight="500.0" prefWidth="900.0" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.industrialsnmpreader.IndustrialSNMPController"
            stylesheets="@style.css">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #004990; -fx-padding: 15;">
            <Label text="Industrial SNMP Monitor" textFill="WHITE" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Wyloguj" onAction="#onLogoutClick" styleClass="button-logout"/>
        </HBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.7">
            <VBox spacing="10" style="-fx-padding: 10;">
                <TableView fx:id="deviceTable" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>

                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="40" style="-fx-alignment: CENTER-LEFT;"/>
                        <TableColumn fx:id="colIp" text="IP" prefWidth="120" style="-fx-alignment: CENTER-LEFT;"/>
                        <TableColumn fx:id="colHostname" text="Hostname" prefWidth="110" style="-fx-alignment: CENTER-LEFT;"/>
                        <TableColumn fx:id="colVendor" text="Vendor" prefWidth="90" style="-fx-alignment: CENTER-LEFT;"/>
                        <TableColumn fx:id="colTemp" text="Temp." prefWidth="70" style="-fx-alignment: CENTER-LEFT;"/>
                        <TableColumn fx:id="colUptime" text="Uptime" prefWidth="130" style="-fx-alignment: CENTER-LEFT;"/>
                        <TableColumn fx:id="colCpu" text="CPU %" prefWidth="70" style="-fx-alignment: CENTER-LEFT;"/>
                        <TableColumn fx:id="colUpdate" text="Odczyt" prefWidth="85" style="-fx-alignment: CENTER-LEFT;"/>
                    </columns>

                </TableView>
            </VBox>
            <VBox spacing="15" style="-fx-padding: 20;">
                <Label text="Dodaj Urządzenie" style="-fx-font-weight: bold;"/>
                <TextField fx:id="ipField" promptText="Adres IP"/>
                <ComboBox fx:id="vendorChoiceBox" maxWidth="Infinity"/>
                <Button text="Dodaj" onAction="#onAddDevice" maxWidth="Infinity" styleClass="button-add"/>
                <Button text="Wykres" onAction="#onShowChart" maxWidth="Infinity" styleClass="button-logout"/>
                <Button text="Usuń" onAction="#onDeleteDevice" maxWidth="Infinity" styleClass="button-delete"/>
                <Label fx:id="statusLabel" text="Gotowy"/>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>